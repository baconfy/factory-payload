{
  "name": "baconfy/factory-payload",
  "description": "Generate HTTP request payloads from Laravel Eloquent factories.",
  "keywords": ["laravel", "factory", "testing", "payload", "http"],
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Renato Dehnhardt",
      "email": "renatotkd@gmail.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "illuminate/database": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0|^11.0",
    "pestphp/pest": "^3.0|^4.0"
  },
  "autoload": {
    "psr-4": {
      "Baconfy\\FactoryPayload\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Baconfy\\FactoryPayload\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}